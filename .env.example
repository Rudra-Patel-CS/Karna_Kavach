# ─── KarnaKavach Environment Configuration ───────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ─── Gemini AI Engine ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─── Firebase Configuration ──────────────────────────────────────────────────
# Copy these values from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
VITE_FIREBASE_DATABASE_ID=your-firestore-database-id
VITE_FIREBASE_MEASUREMENT_ID=
