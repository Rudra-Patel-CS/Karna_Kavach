# ML model artifacts (large binary files, regenerate with train.py)
karnakavach_backend/models/*.pkl

# Feedback dataset (contains user email data — keep private)
karnakavach_backend/feedback_dataset.csv

# ML settings
karnakavach_ml_settings.json

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Keep the example file (safe — no real values)
!.env.example
