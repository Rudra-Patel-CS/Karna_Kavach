rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── users/{uid} ───────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && isOwner(uid);
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && isOwner(uid);
      allow delete: if false;
    }

    // ── settings/{uid} ────────────────────────────────────────────────────
    match /settings/{uid} {
      allow read:   if isSignedIn() && isOwner(uid);
      allow write:  if isSignedIn() && isOwner(uid);
    }

    // ── ml_models/{docId} ────────────────────────────────────────────────────
    // Model version registry — readable by all authenticated users, writable by server-side only
    match /ml_models/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();   // client creates after retraining
      allow update: if isSignedIn();   // for marking active/inactive
      allow delete: if false;
    }

    // ── feedback/{feedbackId} ─────────────────────────────────────────────
    match /feedback/{feedbackId} {
      // Any signed-in user can create feedback for their own scans
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.predictedLabel in ['Phishing', 'Legitimate', 'Suspicious']
        && request.resource.data.correctLabel   in ['Phishing', 'Legitimate', 'Suspicious']
        && request.resource.data.confidence     is number
        && request.resource.data.scanId         is string
        && request.resource.data.sender         is string
        && request.resource.data.subject        is string;

      // Users can only read their own feedback
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Feedback is immutable once submitted
      allow update, delete: if false;
    }

    // ── scans/{scanId} ────────────────────────────────────────────────────
    match /scans/{scanId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.riskScore  is number
        && request.resource.data.riskScore  >= 0
        && request.resource.data.riskScore  <= 100
        && request.resource.data.riskLevel  in ['HIGH', 'MEDIUM', 'LOW']
        && request.resource.data.sender     is string
        && request.resource.data.subject    is string
        && request.resource.data.body       is string
        && request.resource.data.summary    is string
        && request.resource.data.confidence is number;

      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Scans are immutable audit records
      allow update: if false;
    }

    // ── test/connection ───────────────────────────────────────────────────
    match /test/connection {
      allow read: if true;
    }

    // ── Global deny-all fallback ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
